<UserControl
    x:Class="StringDiagram.StringDiagramVertical"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:StringDiagram"
    x:Name="UC"
    Height="Auto"
    x:ClassModifier="internal"
    d:DesignHeight="450"
    d:DesignWidth="800"
    UseLayoutRounding="True"
    Background="{Binding ContainerBrush, RelativeSource={RelativeSource Self}}"
    SnapsToDevicePixels="True"
    ClipToBounds="False"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StringDiagram;component/ImageSources/Imagesouce.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="LayoutRoot" ClipToBounds="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto">
            </ColumnDefinition>
            <ColumnDefinition Width="Auto">
            </ColumnDefinition>
            <ColumnDefinition Width="Auto">
            </ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!--  降额绘制  -->
        <Canvas
            x:Name="Zone"
            Grid.Column="0"
            Height="{Binding ElementName=UC, Path=Height}"
            SnapsToDevicePixels="True"
            Background="Transparent"
            ClipToBounds="False" />

        <!--  画图用的根容器  -->
        <Canvas
            x:Name="Root"
            Grid.Column="1"
            Width="70"
            Height="{Binding ElementName=UC, Path=Height}"
            SnapsToDevicePixels="True"
            ClipToBounds="False"
            Background="Transparent" />
        <!--  标尺绘画区域  -->
        <!--  Height="{Binding ElementName=UC, Path=Height}"  -->

        <Canvas
            x:Name="ruler"
            Grid.Column="2"
            Height="{Binding ElementName=UC, Path=Height}"
            SnapsToDevicePixels="True"
            ClipToBounds="False"
            Background="Transparent">
        </Canvas>

        <!--  选中分段引导线/文字叠加层（跨两列）  -->
        <Canvas
            x:Name="SelectionOverlay"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Height="{Binding ElementName=UC, Path=Height}"
            Panel.ZIndex="99"
            SnapsToDevicePixels="True"
            ClipToBounds="False"
            Background="Transparent"
            IsHitTestVisible="False" />


    </Grid>
</UserControl>
